# --- PROJECT SETTINGS ---
DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "MathApp"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "A simple calculator with Unit Tests and Documentation"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

# --- INPUT SETTINGS ---
# مسیر اصلی کدها و فایل ریدمی
INPUT                  = README.md src/MathApp
FILE_PATTERNS          = *.cs *.md
RECURSIVE              = YES
EXCLUDE                = **/obj/** **/bin/**

# --- C# OPTIMIZATION ---
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

# --- BUILD SETTINGS ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
SHOW_USED_FILES        = YES

# --- HTML SETTINGS ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# این بخش باعث می‌شود README صفحه اصلی باشد و منو درختی در سمت چپ ظاهر شود
USE_MDRIP              = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_PATH_NAMES        = YES

# --- DISABLE UNUSED FORMATS ---
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO