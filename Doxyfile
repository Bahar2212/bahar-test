# --- PROJECT SETTINGS ---
PROJECT_NAME           = "MathApp"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "Calculator with Unit Tests and Documentation"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

# --- INPUT SETTINGS ---
# فقط پوشه کدها را اسکن می‌کنیم تا گیج نشود
INPUT                  = src/MathApp
FILE_PATTERNS          = *.cs
RECURSIVE              = YES
EXCLUDE                = **/obj/** **/bin/**

# --- C# OPTIMIZATION ---
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

# --- BUILD SETTINGS ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
SHOW_USED_FILES        = YES

# --- HTML SETTINGS (IMPORTANT FIX) ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# این بخش جادویی: لیست کلاس‌ها را مستقیماً صفحه اول می‌کند
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = NO
# این خط باعث می‌شود لیست کلاس‌ها اولین چیزی باشد که می‌بینی
HTML_DYNAMIC_MENUS     = NO

# --- DISABLE UNUSED FORMATS ---
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO